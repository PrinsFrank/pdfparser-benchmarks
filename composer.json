{
    "name": "prinsfrank/pdfparser-benchmarks",
    "description": "Generates benchmarks for PHP PDFParser libraries",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "alpha",
    "autoload": {
        "psr-4": {
            "PrinsFrank\\PDFParserBenchmarks\\": "src/"
        }
    },
    "require": {
        "prinsfrank/pdfparser": "dev-main",
        "smalot/pdfparser": "dev-master"
    },
    "repositories": [
        {
            "type": "git",
            "no-api": true,
            "url": "https://github.com/Smalot/pdfparser"
        },
        {
            "type": "git",
            "no-api": true,
            "url": "https://github.com/PrinsFrank/pdfparser"
        }
    ],
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --allow-risky=yes --dry-run",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "benchmark": "./run"
    }
}
